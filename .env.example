# Database
DATABASE_URL=postgresql+asyncpg://pwps:pwps@localhost:5432/pwps_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Local artifact storage
LOCAL_ARTIFACT_DIR=./storage/artifacts

# LLM Provider: deepseek | openai
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0

# Embedding (SiliconFlow, OpenAI-compatible API)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# Reranker (SiliconFlow)
RERANKER_API_KEY=
RERANKER_BASE_URL=https://api.siliconflow.cn/v1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Milvus
MILVUS_URI=http://localhost:19530

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Web Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
